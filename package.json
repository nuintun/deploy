{
  "name": "@nuintun/deploy",
  "version": "1.0.0",
  "description": "Deployment tool for FTP and SVN",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "deploy": "./esm/cli.js"
  },
  "exports": {
    ".": {
      "import": "./esm/index.js",
      "require": "./cjs/index.cjs",
      "default": "./esm/index.js"
    }
  },
  "author": {
    "name": "nuintun",
    "email": "nuintun@qq.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nuintun/deploy/issues"
  },
  "homepage": "https://github.com/nuintun/deploy#readme",
  "scripts": {
    "lint": "tsc --noEmit",
    "pretest": "pnpm build",
    "test": "node tests/index.ts",
    "clean": "node tools/clean.ts",
    "prepublishOnly": "pnpm build",
    "build:cjs": "rollup -c tools/rollup.cjs.ts",
    "build:esm": "rollup -c tools/rollup.esm.ts",
    "build:fix-types": "node tools/fix-types.ts",
    "format": "prettier --write . --ignore-path .prettierignore",
    "build": "pnpm build:cjs && pnpm build:esm && pnpm build:fix-types && pnpm format"
  },
  "dependencies": {
    "basic-ftp": "^6.0.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.6.2",
    "dts-paths": "^2.2.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
